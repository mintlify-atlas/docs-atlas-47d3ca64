{
  "projectType": "sdk-library",
  "projectName": "decomp",
  "projectDescription": "A Go library providing matrix decomposition algorithms including QR, Schur, Hessenberg, Eigen, and Parlett methods for complex-valued matrices.",
  "theme": "luma",
  "primaryColor": "#2563EB",
  "lightColor": "#DBEAFE",
  "darkColor": "#1E3A8A",
  "navigation": {
    "tabs": [
